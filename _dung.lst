 94+  8F79              ; Zamienia liczbe z zakresu 1-16 na slowo z ustawionym bitem od 1-16
 95+  8F79              ; IN:	A - liczba 1 - 16
 96+  8F79              ;		DE - adres slowa flag
 97+  8F79              ; OUT:	A - ustawiony odpowiedni bit flagi
 98+  8F79              ;		C - odpowiedni bajt flagi
 99+  8F79              ; -------------------------------------------------------------------
100+  8F79              nr_to_bit:
101+  8F79 FE 08        		cp	8
102+  8F7B 38 03        		jr	c,_low_flags
103+  8F7D 13           		inc	de
104+  8F7E D6 08        		sub	8
105+  8F80              _low_flags:
106+  8F80 47           		ld	b,a						; ile razy przesuwka
107+  8F81 1A           		ld	a,(de)					; hl zajete wyzej
108+  8F82 4F           		ld	c,a
109+  8F83 3E 01        		ld	a,%00000001
110+  8F85              _roll_right:
111+  8F85 0F           		rrca
112+  8F86 10 FD        		djnz	_roll_right
113+  8F88 C9           		ret
