 73+  8F69              ; --------------------------------------
 74+  8F69              ; Zamiana 2-cyfrowej liczby dziesietnej
 75+  8F69              ; w formacie ASCII na liczbe 8-bit
 76+  8F69              ; input: (HL)	output: A
 77+  8F69              ; --------------------------------------
 78+  8F69              ascii2num:
 79+  8F69 7E           		ld	a,(hl)			; pierwszy obrot Y
 80+  8F6A E6 0F        		and	0Fh			; minus ascii bits
 81+  8F6C 87           		add	a,a			; x 2
 82+  8F6D 4F           		ld	c,a
 83+  8F6E 87           		add	a,a
 84+  8F6F 87           		add	a,a
 85+  8F70 81           		add	a,c			; x 10
 86+  8F71 4F           		ld	c,a			; save dziesiatki
 87+  8F72 23           		inc	hl
 88+  8F73 7E           		ld	a,(hl)
 89+  8F74 E6 0F        		and	0Fh
 90+  8F76 81           		add	a,c			; dziesietne + jednoscioci
 91+  8F77 23           		inc	hl
 92+  8F78 C9           		ret
