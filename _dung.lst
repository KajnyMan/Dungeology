 94+  8F90              ; Zamienia liczbe z zakresu 1-16 na slowo z ustawionym bitem od 1-16
 95+  8F90              ; IN:	A - liczba 1 - 16
 96+  8F90              ;		DE - adres slowa flag
 97+  8F90              ; OUT:	A - ustawiony odpowiedni bit flagi
 98+  8F90              ;		C - odpowiedni bajt flagi
 99+  8F90              ; -------------------------------------------------------------------
100+  8F90              nr_to_bit:
101+  8F90 FE 08        		cp	8
102+  8F92 38 03        		jr	c,_low_flags
103+  8F94 13           		inc	de
104+  8F95 D6 08        		sub	8
105+  8F97              _low_flags:
106+  8F97 47           		ld	b,a						; ile razy przesuwka
107+  8F98 1A           		ld	a,(de)					; hl zajete wyzej
108+  8F99 4F           		ld	c,a
109+  8F9A 3E 01        		ld	a,%00000001
110+  8F9C              _roll_right:
111+  8F9C 0F           		rrca
112+  8F9D 10 FD        		djnz	_roll_right
113+  8F9F C9           		ret
