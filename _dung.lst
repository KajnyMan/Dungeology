 51+  8F6C              ;-----------------------------
 52+  8F6C              ; Funkja zamienia liczbe w A
 53+  8F6C              ; na pare cyfr ASCII w C i B
 54+  8F6C              ; np.0Fh -> C=1, B=5
 55+  8F6C              ;-----------------------------
 56+  8F6C              h2asci:
 57+  8F6C 0E 00        		ld	c,0
 58+  8F6E              _loop2:
 59+  8F6E 47           		ld	b,a
 60+  8F6F FE 0A        		cp	10
 61+  8F71 38 05        		jr	c,_fine	;jesli a<10 koniec
 62+  8F73 0C           		inc	c
 63+  8F74 D6 0A        		sub	10
 64+  8F76 18 F6        		jr	_loop2
 65+  8F78              _fine:
 66+  8F78 C6 30        		add	a,'0'
 67+  8F7A 47           		ld	b,a
 68+  8F7B 79           		ld	a,c
 69+  8F7C C6 30        		add	a,'0'
 70+  8F7E 4F           		ld	c,a
 71+  8F7F C9           		ret
 72+  8F80
 73+  8F80              ; --------------------------------------
 74+  8F80              ; Zamiana 2-cyfrowej liczby dziesietnej
 75+  8F80              ; w formacie ASCII na liczbe 8-bit
 76+  8F80              ; input: (HL)	output: A
 77+  8F80              ; --------------------------------------
 78+  8F80              ascii2num:
 79+  8F80 7E           		ld	a,(hl)			; pierwszy obrot Y
 80+  8F81 E6 0F        		and	0Fh			; minus ascii bits
 81+  8F83 87           		add	a,a			; x 2
 82+  8F84 4F           		ld	c,a
 83+  8F85 87           		add	a,a
 84+  8F86 87           		add	a,a
 85+  8F87 81           		add	a,c			; x 10
 86+  8F88 4F           		ld	c,a			; save dziesiatki
 87+  8F89 23           		inc	hl
 88+  8F8A 7E           		ld	a,(hl)
 89+  8F8B E6 0F        		and	0Fh
 90+  8F8D 81           		add	a,c			; dziesietne + jednoscioci
 91+  8F8E 23           		inc	hl
 92+  8F8F C9           		ret
