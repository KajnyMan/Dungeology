 28+  8F6C              ; -----------------------------------
 29+  8F6C              ; mulproduct8:
 30+  8F6C              ;		push	bc
 31+  8F6C              ;		ld	a,0
 32+  8F6C              ;	nxtadd:	add a,c
 33+  8F6C              ;		djnz nxtadd
 34+  8F6C              ;		pop	bc
 35+  8F6C              ;		ret
 36+  8F6C              ; Szybsza dla duzych mnoznikow ( > 8 )
 37+  8F6C              ; mulproduct8:
 38+  8F6C              ;		push	bc
 39+  8F6C              ;
 40+  8F6C              ;		ld	a,0
 41+  8F6C              ;	loop1:	bit	0,b
 42+  8F6C              ;		jr	z,skip2
 43+  8F6C              ;		add	a,c
 44+  8F6C              ;	skip2:	sla	c
 45+  8F6C              ;		srl	b
 46+  8F6C              ;		jr	nz,loop1
 47+  8F6C              ;		pop	bc
 48+  8F6C              ;		ret
