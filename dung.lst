 71+  9370              ;		C - odpowiedni bajt flagi
 72+  9370              ; -------------------------------------------------------------------
 73+  9370              nr_to_bit:
 74+  9370 FE 09        		cp	9
 75+  9372 38 03        		jr	c,_low_flags
 76+  9374 13           		inc	de
 77+  9375 D6 08        		sub	8
 78+  9377              _low_flags:
 79+  9377 47           		ld	b,a						; ile razy przesuwka
 80+  9378 1A           		ld	a,(de)					; hl zajete wyzej
 81+  9379 4F           		ld	c,a
 82+  937A 3E 01        		ld	a,%00000001
 83+  937C              _roll_right:
 84+  937C 0F           		rrca
 85+  937D 10 FD        		djnz	_roll_right
 86+  937F C9           		ret
