 14+  930C 29           _loop:	add	hl,hl
 15+  930D 17           		rla
 16+  930E 30 01        		jr	nc,_skip
 17+  9310 19           		add	hl,de
 18+  9311 10 F9        _skip:	djnz	_loop
 19+  9313
 20+  9313 D1           		pop	de
 21+  9314 C1           		pop	bc
 22+  9315 C9           		ret
