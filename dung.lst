 51+  92C3              ;-----------------------------
 52+  92C3              ; Funkja zamienia liczbe w A
 53+  92C3              ; na pare cyfr ASCII w C i B
 54+  92C3              ; np.0Fh -> C=1, B=5
 55+  92C3              ;-----------------------------
 56+  92C3              h2asci:
 57+  92C3 0E 00        		ld	c,0
 58+  92C5              _loop2:
 59+  92C5 47           		ld	b,a
 60+  92C6 FE 0A        		cp	10
 61+  92C8 38 05        		jr	c,_fine	;jesli a<10 koniec
 62+  92CA 0C           		inc	c
 63+  92CB D6 0A        		sub	10
 64+  92CD 18 F6        		jr	_loop2
 65+  92CF              _fine:
 66+  92CF C6 30        		add	a,'0'
 67+  92D1 47           		ld	b,a
 68+  92D2 79           		ld	a,c
 69+  92D3 C6 30        		add	a,'0'
 70+  92D5 4F           		ld	c,a
 71+  92D6 C9           		ret
 72+  92D7
 73+  92D7              ; --------------------------------------
 74+  92D7              ; Zamiana 2-cyfrowej liczby dziesietnej
 75+  92D7              ; w formacie ASCII na liczbe 8-bit
 76+  92D7              ; input: (HL)	output: A
 77+  92D7              ; --------------------------------------
 78+  92D7              ascii2num:
 79+  92D7 7E           		ld	a,(hl)			; pierwszy obrot Y
 80+  92D8 E6 0F        		and	0Fh			; minus ascii bits
 81+  92DA 87           		add	a,a			; x 2
 82+  92DB 4F           		ld	c,a
 83+  92DC 87           		add	a,a
 84+  92DD 87           		add	a,a
 85+  92DE 81           		add	a,c			; x 10
 86+  92DF 4F           		ld	c,a			; save dziesiatki
 87+  92E0 23           		inc	hl
 88+  92E1 7E           		ld	a,(hl)
 89+  92E2 E6 0F        		and	0Fh
 90+  92E4 81           		add	a,c			; dziesietne + jednoscioci
 91+  92E5 23           		inc	hl
 92+  92E6 C9           		ret
 93+  92E7              ; -------------------------------------------------------------------
 94+  92E7              ; Zamienia liczbe z zakresu 1-16 na slowo z ustawionym bitem od 1-16
 95+  92E7              ; IN:	A - liczba 1 - 16
 96+  92E7              ;		DE - adres slowa flag
 97+  92E7              ; OUT:	A - ustawiony odpowiedni bit flagi
 98+  92E7              ;		C - odpowiedni bajt flagi
 99+  92E7              ; -------------------------------------------------------------------
100+  92E7              nr_to_bit:
101+  92E7 FE 09        		cp	9
102+  92E9 38 03        		jr	c,_low_flags
103+  92EB 13           		inc	de
104+  92EC D6 08        		sub	8
105+  92EE              _low_flags:
106+  92EE 47           		ld	b,a						; ile razy przesuwka
107+  92EF 1A           		ld	a,(de)					; hl zajete wyzej
108+  92F0 4F           		ld	c,a
109+  92F1 3E 01        		ld	a,%00000001
110+  92F3              _roll_right:
111+  92F3 0F           		rrca
112+  92F4 10 FD        		djnz	_roll_right
113+  92F6 C9           		ret
114+  92F7
115+  92F7              ; -------------------------------------------------------------------
116+  92F7              ; Zamienia slowo z ustawionym bitem od 1-16 na liczbe z zakresu 1-16
117+  92F7              ; IN:	DE - adres slowa flag
118+  92F7              ; OUT:	C - liczba od 1 do 16
119+  92F7              ; -------------------------------------------------------------------
