 37+  92D3              ; mulproduct8:
 38+  92D3              ;		push	bc
 39+  92D3              ;
 40+  92D3              ;		ld	a,0
 41+  92D3              ;	loop1:	bit	0,b
 42+  92D3              ;		jr	z,skip2
 43+  92D3              ;		add	a,c
 44+  92D3              ;	skip2:	sla	c
 45+  92D3              ;		srl	b
 46+  92D3              ;		jr	nz,loop1
 47+  92D3              ;		pop	bc
 48+  92D3              ;		ret
