 47+  9360              ; Zamiana 2-cyfrowej liczby dziesietnej
 48+  9360              ; w formacie ASCII na liczbe 8-bit
 49+  9360              ; input: (HL)	output: A
 50+  9360              ; --------------------------------------
 51+  9360              ascii2num:
 52+  9360 7E           		ld	a,(hl)			; pierwszy obrot Y
 53+  9361 E6 0F        		and	0Fh			; minus ascii bits
 54+  9363 87           		add	a,a			; x 2
 55+  9364 4F           		ld	c,a
 56+  9365 87           		add	a,a
 57+  9366 87           		add	a,a
 58+  9367 81           		add	a,c			; x 10
 59+  9368 4F           		ld	c,a			; save dziesiatki
 60+  9369 23           		inc	hl
 61+  936A 7E           		ld	a,(hl)
 62+  936B E6 0F        		and	0Fh
 63+  936D 81           		add	a,c			; dziesietne + jednoscioci
 64+  936E 23           		inc	hl
 65+  936F C9           		ret
