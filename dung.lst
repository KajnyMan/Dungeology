 24+  92D3              ; -----------------------------------
 25+  92D3              ; Mnozenie takich liczb aby iloczyn
 26+  92D3              ; byl 8-bitowy.
 27+  92D3              ; czynniki: B,C   iloczyn: A
 28+  92D3              ; -----------------------------------
 29+  92D3              ; mulproduct8:
 30+  92D3              ;		push	bc
 31+  92D3              ;		ld	a,0
 32+  92D3              ;	nxtadd:	add a,c
 33+  92D3              ;		djnz nxtadd
 34+  92D3              ;		pop	bc
 35+  92D3              ;		ret
