 47+  932A              ; Zamiana 2-cyfrowej liczby dziesietnej
 48+  932A              ; w formacie ASCII na liczbe 8-bit
 49+  932A              ; input: (HL)	output: A
 50+  932A              ; --------------------------------------
 51+  932A              ascii2num:
 52+  932A 7E           		ld	a,(hl)			; pierwszy obrot Y
 53+  932B E6 0F        		and	0Fh			; minus ascii bits
 54+  932D 87           		add	a,a			; x 2
 55+  932E 4F           		ld	c,a
 56+  932F 87           		add	a,a
 57+  9330 87           		add	a,a
 58+  9331 81           		add	a,c			; x 10
 59+  9332 4F           		ld	c,a			; save dziesiatki
 60+  9333 23           		inc	hl
 61+  9334 7E           		ld	a,(hl)
 62+  9335 E6 0F        		and	0Fh
 63+  9337 81           		add	a,c			; dziesietne + jednoscioci
 64+  9338 23           		inc	hl
 65+  9339 C9           		ret
