 50+  92D3
 51+  92D3              ;-----------------------------
 52+  92D3              ; Funkja zamienia liczbe w A
 53+  92D3              ; na pare cyfr ASCII w C i B
 54+  92D3              ; np.0Fh -> C=1, B=5
 55+  92D3              ;-----------------------------
 56+  92D3              h2asci:
 57+  92D3 0E 00        		ld	c,0
 58+  92D5              _loop2:
 59+  92D5 47           		ld	b,a
 60+  92D6 FE 0A        		cp	10
 61+  92D8 38 05        		jr	c,_fine	;jesli a<10 koniec
 62+  92DA 0C           		inc	c
 63+  92DB D6 0A        		sub	10
 64+  92DD 18 F6        		jr	_loop2
 65+  92DF              _fine:
 66+  92DF C6 30        		add	a,'0'
 67+  92E1 47           		ld	b,a
 68+  92E2 79           		ld	a,c
 69+  92E3 C6 30        		add	a,'0'
 70+  92E5 4F           		ld	c,a
 71+  92E6 C9           		ret
 72+  92E7
 73+  92E7              ; --------------------------------------
 74+  92E7              ; Zamiana 2-cyfrowej liczby dziesietnej
 75+  92E7              ; w formacie ASCII na liczbe 8-bit
 76+  92E7              ; input: (HL)	output: A
 77+  92E7              ; --------------------------------------
 78+  92E7              ascii2num:
 79+  92E7 7E           		ld	a,(hl)			; pierwszy obrot Y
 80+  92E8 E6 0F        		and	0Fh			; minus ascii bits
 81+  92EA 87           		add	a,a			; x 2
 82+  92EB 4F           		ld	c,a
 83+  92EC 87           		add	a,a
 84+  92ED 87           		add	a,a
 85+  92EE 81           		add	a,c			; x 10
 86+  92EF 4F           		ld	c,a			; save dziesiatki
 87+  92F0 23           		inc	hl
 88+  92F1 7E           		ld	a,(hl)
 89+  92F2 E6 0F        		and	0Fh
 90+  92F4 81           		add	a,c			; dziesietne + jednoscioci
 91+  92F5 23           		inc	hl
 92+  92F6 C9           		ret
 93+  92F7              ; -------------------------------------------------------------------
 94+  92F7              ; Zamienia liczbe z zakresu 1-16 na slowo z ustawionym bitem od 1-16
 95+  92F7              ; IN:	A - liczba 1 - 16
 96+  92F7              ;		DE - adres slowa flag
 97+  92F7              ; OUT:	A - ustawiony odpowiedni bit flagi
 98+  92F7              ;		C - odpowiedni bajt flagi
 99+  92F7              ; -------------------------------------------------------------------
100+  92F7              nr_to_bit:
101+  92F7 FE 09        		cp	9
102+  92F9 38 03        		jr	c,_low_flags
103+  92FB 13           		inc	de
104+  92FC D6 08        		sub	8
105+  92FE              _low_flags:
106+  92FE 47           		ld	b,a						; ile razy przesuwka
107+  92FF 1A           		ld	a,(de)					; hl zajete wyzej
108+  9300 4F           		ld	c,a
109+  9301 3E 01        		ld	a,%00000001
110+  9303              _roll_right:
111+  9303 0F           		rrca
112+  9304 10 FD        		djnz	_roll_right
113+  9306 C9           		ret
