 29+  934C              h2asci:
 30+  934C 0E 00        		ld	c,0
 31+  934E              _loop2:
 32+  934E 47           		ld	b,a
 33+  934F FE 0A        		cp	10
 34+  9351 38 05        		jr	c,_fine	;jesli a<10 koniec
 35+  9353 0C           		inc	c
 36+  9354 D6 0A        		sub	10
 37+  9356 18 F6        		jr	_loop2
 38+  9358              _fine:
 39+  9358 C6 30        		add	a,'0'
 40+  935A 47           		ld	b,a
 41+  935B 79           		ld	a,c
 42+  935C C6 30        		add	a,'0'
 43+  935E 4F           		ld	c,a
 44+  935F C9           		ret
