 28+  9316              ;-----------------------------
 29+  9316              h2asci:
 30+  9316 0E 00        		ld	c,0
 31+  9318              _loop2:
 32+  9318 47           		ld	b,a
 33+  9319 FE 0A        		cp	10
 34+  931B 38 05        		jr	c,_fine	;jesli a<10 koniec
 35+  931D 0C           		inc	c
 36+  931E D6 0A        		sub	10
 37+  9320 18 F6        		jr	_loop2
 38+  9322              _fine:
 39+  9322 C6 30        		add	a,'0'
 40+  9324 47           		ld	b,a
 41+  9325 79           		ld	a,c
