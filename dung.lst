 71+  933A              ;		C - odpowiedni bajt flagi
 72+  933A              ; -------------------------------------------------------------------
 73+  933A              nr_to_bit:
 74+  933A FE 09        		cp	9
 75+  933C 38 03        		jr	c,_low_flags
 76+  933E 13           		inc	de
 77+  933F D6 08        		sub	8
 78+  9341              _low_flags:
 79+  9341 47           		ld	b,a						; ile razy przesuwka
 80+  9342 1A           		ld	a,(de)					; hl zajete wyzej
 81+  9343 4F           		ld	c,a
 82+  9344 3E 01        		ld	a,%00000001
 83+  9346              _roll_right:
 84+  9346 0F           		rrca
 85+  9347 10 FD        		djnz	_roll_right
 86+  9349 C9           		ret
