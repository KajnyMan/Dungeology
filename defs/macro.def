MUL_Ax8_TO_HL	MACRO
		ld	h,0
		ld	l,a
		add	hl,hl
		add	hl,hl
		add	hl,hl
		ENDM
; ========================
		
CLEAR_LINES	MACRO	_end_of_area, _lines
		ld	de,0000h		
		ld	hl,0000h
		add	hl,sp			; save SP
		ld	sp,_end_of_area	; czysci od gory 
		ld	b,_lines		; 192 = 6144 / ( 16 x 2 )
.clear_block:
	REPT	16				; zeruje 32 bajty na obrot
		push	de	
	ENDR
		djnz	.clear_block	
		ld	sp,hl			; restore SP
		ENDM
; =======================
clear_txtline	MACRO _txtline
		ld	hl,_txtline
		ld	e,l
		ld	b,8
		xor	a
.clear_block:
	REPT	32
		ld	(hl),a
		inc	hl
	ENDR			
		ld	l,e
		inc	h
		djnz	.clear_block	
		ENDM

; =======================
BORDER_COLOR	MACRO	_color
		ld	a,_color
		out	(0FEh),a
		ENDM
	
; =======================
SET_COLOR	MACRO _paper_ink, _adress, _rows
		ld de, _paper_ink * 256 + _paper_ink
		ld	hl,0000h
		add	hl,sp			; save SP
		ld	sp,_adress
		ld	b,_rows
.colour_block:
	REPT	16				; zeruje 32 bajty na obrot
		push	de	
	ENDR
		djnz	.colour_block	
		ld	sp,hl			; restore SP
		ENDM

; =================
; IN:	Y,X w DE
; =================
SET_ATR_LINE	MACRO _paper_ink, _col
		ld	a,d
		add	a,a
		add	a,a
		add	a,a
		ld	l,a
		ld	h,0
		add	hl,hl
		add hl,hl
		ld	a,e
		add	a,l
		ld	l,a
		ld	a,ATR_MSB	
		add	a,h
		ld	h,a
		ld	a,_paper_ink
	IF	NUL _col
		ld	(hl),a
		inc	l
	ELSE
		REPT	_col
			ld	(hl),a
			inc	l
		ENDR
	ENDIF
		ENDM
			
; =========================
SET_ATR_BLOCK	MACRO _paper_ink, _col, _lines
		ld	b,_lines
.next_ln:
		set_atr _paper_ink, _col
		inc	d
		djnz	.next_ln
		ENDM

; =========================
; IN : DE - adres Tile na ekranie, A'- atrybut
print_attribute_2buffer	MACRO
		ld	h,ATR3_BUF_MSB
		ld	l,e
		ex	af,af'
		ld	(hl),a
		ex	af,af'
		ENDM

; ========================
PRINT_ATR	MACRO
		ld	a,d
		cp	$48
		jr	z,t2
		jr	nc,t3
		ld	h,ATR1_MSB
		jr	cmn
t2:
		ld	h,ATR2_MSB
		jr	cmn
t3: 
		ld	h,ATR3_BUF_MSB
cmn:
		ld	l,e
		ex	af,af'
		ld	(hl),a
		ex	af,af'
		ENDM

; =========================
PRINT_STR	MACRO	_scradr, _msgadr
		ld	de,_scradr
		ld	bc,_msgadr
		call	pstring
		ENDM

; ===========================
atrbuf_2_atr	MACRO
		ld	de,ATR3
		ld	hl,ATR3_BUF
		ld	bc,32 * 8
		ldir
		ENDM
